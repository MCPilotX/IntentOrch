{
  "name": "@intentorch/core",
  "version": "0.8.0",
  "description": "Core business logic for IntentOrch - MCP Ecosystem Orchestration Platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/ai",
    "dist/core",
    "dist/daemon",
    "dist/kernel",
    "dist/mcp",
    "dist/process-manager",
    "dist/registry",
    "dist/runtime",
    "dist/secret",
    "dist/tool-registry",
    "dist/types",
    "dist/utils",
    "dist/workflow",
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "orchestration",
    "ai",
    "core",
    "intent",
    "workflow"
  ],
  "author": "MCPilotX",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcpilotx/intentorch.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mcpilotx/intentorch/issues"
  },
  "homepage": "https://github.com/mcpilotx/intentorch#readme",
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-validator": "^0.8.0",
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.9",
    "chalk": "^4.1.2",
    "eventsource": "^3.0.7",
    "hono": "^4.12.18",
    "jexl": "^2.3.0",
    "lodash": "^4.18.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^29.5.14",
    "@types/jexl": "^2.3.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}