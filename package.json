{
  "name": "@mcpilotx/sdk-core",
  "version": "0.3.0",
  "description": "Core SDK for MCP service orchestration - Developer-focused, simple and elegant",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --outDir dist --project tsconfig.json",
    "build:prod": "tsc --outDir dist --project tsconfig.json --declaration false --declarationMap false --sourceMap false",
    "test": "jest --config jest.config.js",
    "clean": "rm -rf dist",
    "dev": "tsc --watch --outDir dist --project tsconfig.json",
    "prepublishOnly": "npm run build:prod && npm test"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "dotenv": "^17.3.1",
    "uuid": "^11.0.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.12",
    "@jest/globals": "^29.7.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "orchestration",
    "sdk",
    "docker",
    "nodejs",
    "python",
    "go",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MCPilotX/sdk-core.git",
    "directory": "sdk-core"
  },
  "bugs": {
    "url": "https://github.com/MCPilotX/sdk-core/issues"
  },
  "homepage": "https://github.com/MCPilotX/sdk-core#readme",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "README.ZH_CN.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
